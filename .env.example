# CodeXray environment variables (all optional). Copy to .env.local to override.

# The backend CodeXray observes for live /metrics + /logs. Defaults to :8000.
# Leave unset to run the dashboard with the static map only ("Connect your repo").
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Which project map to show by default (matches an id registered in app/configs/).
# Can also be chosen at runtime via the ?project=<id> URL param.
NEXT_PUBLIC_PROJECT=example
